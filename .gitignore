# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
build/
dist/

# Runs — keep summaries, not raw traces
runs/*
!runs/.gitkeep
!runs/**/report.md
!runs/report_*.md
!runs/results_*.jsonl
!runs/errors_*.jsonl
!runs/**/summary.json
# Reproducibility snapshots: raw traces cited in report_v1 are always tracked
!runs/reproducibility/
!runs/reproducibility/**

# Local secrets
.env
.env.*
!.env.example

# Editor
.vscode/
.idea/
*.swp
.DS_Store
